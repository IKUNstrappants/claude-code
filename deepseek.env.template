# DeepSeek Configuration for Claude Code
# Copy to ~/.config/claude-code/deepseek.env and fill in your API key.
#
# IMPORTANT: launcher scripts will override ANTHROPIC_MODEL and
# ANTHROPIC_BASE_URL regardless of what's set here. These values
# serve as fallbacks only.

export ANTHROPIC_BASE_URL='https://api.deepseek.com/anthropic'
export ANTHROPIC_API_KEY='your-api-key-here'
export ANTHROPIC_MODEL='deepseek-v4-pro'
export ANTHROPIC_SMALL_FAST_MODEL='deepseek-v4-flash'
export CLAUDE_CODE_MAX_CONTEXT_TOKENS='1048576'
export CLAUDE_CODE_MAX_OUTPUT_TOKENS='393216'
export API_TIMEOUT_MS='600000'
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC='1'
unset ANTHROPIC_AUTH_TOKEN
unset CLAUDE_CODE_USE_BEDROCK
unset CLAUDE_CODE_USE_VERTEX
unset CLAUDE_CODE_USE_FOUNDRY
